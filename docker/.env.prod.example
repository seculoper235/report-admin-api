# 관리자 API 운영 시크릿/설정. 이 파일을 docker/.env.prod 로 복사한 뒤 값을 채운다.
# .env.prod 는 절대 커밋하지 않는다(.gitignore 처리됨).
#
# 중요: admin-api는 front-api(daily-prod)의 DB/Redis를 공유하므로
#       DB_USER / DB_PASSWORD / JWT_SECRET 은 front-api의 .env.prod 와 "동일한 값"을 써야 한다.

# (선택) JVM 메모리 튜닝. 미지정 시 컨테이너 메모리의 75%를 힙으로 사용.
#JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# front-api와 동일해야 함 (같은 Postgres/회원 공유)
DB_USER=devteller
DB_PASSWORD=change-me-strong-password

# front-api와 동일해야 함 (회원/토큰 공유)
JWT_SECRET=replace-with-a-long-random-32byte-minimum-secret

# AWS S3 (front-api와 같은 버킷 사용)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BUCKET=report-product-bucket
AWS_S3_PRIVATE_BUCKET=report-gift-bucket
